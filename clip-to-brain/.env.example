# Clip-to-Brain 环境变量（复制为 ../../.env.local）

# ===== 必填：LLM =====
LLM_API_KEY=sk-your-key-here
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
LLM_PROVIDER=deepseek

# ===== 可选：默认 Profile =====
# CLIP_PROFILE=default-creator
# CLIP_PROFILE=tutorial-blogger

# ===== 可选：Telegram Bot =====
# TELEGRAM_BOT_TOKEN=

# ===== 可选：飞书 Bot =====
# FEISHU_APP_ID=
# FEISHU_APP_SECRET=

# ===== Docker / API 服务 =====
# SERVE_WEB_UI=true
# API_PORT=8765
# WHISPER_MODEL=small
