# ============================================================
# 视频去水印 & 逐字稿 — 环境变量配置
# 复制为 .env 后填写
# ============================================================

# ── 转写（本地 Whisper 推荐）──
TRANSCRIBE_BACKEND=local
WHISPER_MODEL=medium
WHISPER_LANGUAGE=zh
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=float16
WHISPER_BEAM_SIZE=5
# FFMPEG_PATH=/usr/bin/ffmpeg

# ── 服务 ──
API_HOST=0.0.0.0
API_PORT=8765

# ── 安全（对外暴露时建议全部开启）──
API_KEY=
# 本地自用 + 浏览器插件：设为 false，无需 API Key
REQUIRE_API_KEY=false
# 多租户账户文件（商业用途：每客户独立 Key，见 scripts/manage_accounts.py）
# ACCOUNTS_FILE=accounts.json
DOCS_ENABLED=false
SERVE_WEB_UI=false
RATE_LIMIT_PER_MINUTE=20
# 转写 video_url 校验：cdn=白名单+禁内网 | any=仅禁内网（不推荐公网）
TRANSCRIBE_URL_MODE=cdn
# 追加 CDN 后缀，逗号分隔
# ALLOWED_VIDEO_HOSTS=xhscdn.com,douyinvod.com
# 浏览器跨域（留空=不启用 CORS，纯服务端调用无需设置）
# CORS_ORIGINS=
# 浏览器插件默认允许 chrome-extension:// 来源（本地 API 建议保持 true）
EXTENSION_CORS=true

# Lumis 一键入库配置（浏览器插件 POST /ingest 使用）
# INGEST_CONFIG=D:/0-CryptoLumis/5-automedia/content-archiver-skill/config.json

# ── 可选：微信视频号 ──
YUANBAO_COOKIE=
WX_SPH_API=https://sph.litao.workers.dev/api/fetch_video_profile

# ── 可选：代理 ──
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890

# ── 可选：阿里云转写（TRANSCRIBE_BACKEND=aliyun）──
# ALIYUN_AK_ID=
# ALIYUN_AK_SECRET=
# NLS_APP_KEY=
